{
    "mode": "local",
    "auth": {
	"mode": "token",
	"token": "123456"
    },
    "port": 18789,
    "bind": "lan",
    "tailscale": {
	"mode": "off",
	"resetOnExit": false
    },
    "controlUi": {
	"allowInsecureAuth": true,
	"allowedOrigins": [
            "http://localhost:18789",
            "http://127.0.0.1:18789"
	]
    },
    "nodes": {
	"denyCommands": [
            "camera.snap",
            "camera.clip",
            "screen.record",
            "contacts.add",
            "calendar.add",
            "reminders.add",
            "sms.send",
            "sms.search"
	]
    }
}
